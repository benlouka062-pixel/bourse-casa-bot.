    print(f"News trouvées: {result['nombre_news']}")
    
    if result['news']:
        print("\n📰 Dernières news:")
        for n in result['news']:
            print(f"  • {n['source']} - {n['titre']}")
            print(f"    Sentiment: {n['sentiment']['label']}")
